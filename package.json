{
	"name": "n8n-nodes-fluig",
	"version": "1.1.0",
	"description": "Packet of n8n nodes to integrate with Fluig API",
	"license": "MIT",
	"homepage": "",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "aldoiguerra",
		"email": "aldoiguerra@gmail.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/aldoiguerra/n8n-nodes-fluig.git"
	},
	"scripts": {
		"build": "n8n-node build && cp -r nodes/Fluig/resources/vendor dist/nodes/Fluig/resources/vendor",
		"build:watch": "tsc --watch",
		"dev": "cp -r nodes/Fluig/resources/vendor dist/nodes/Fluig/resources/vendor && n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/FluigOAuth1Api.credentials.js"
		],
		"nodes": [
			"dist/nodes/Fluig/Fluig.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"@types/node": "^25.3.2",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
